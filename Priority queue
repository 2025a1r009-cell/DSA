#include<stdio.h>
#define MAX 100
struct queue{
    int data;
    int priority;
};
struct queue pqueue[MAX];
int front = -1, rear = -1;
int isfull(){
    return front == MAX-1;
}
int isempty(){
    return front  == -1;
}
void enqueue(int data, int priority){
    if(isfull){
        printf("Queue Overflow!!!\n");
        return ;
    }
    front++;
    pqueue[rear].data = data;
    pqueue[rear].priority = priority;
    if(front == -1){
        front = rear ;
        printf("Element inserted in priority queue!!!\n");
    }
}
int index;
 int gethighestpriority(){
    int max = pqueue[0].priority;
    for(int i=0;i<=rear;i++){
        if(pqueue[i].priority > max){
            max = pqueue[i].priority;
           index = i;
        }
    }
    return index;
 } 
int dequeue(){
    if(isempty()){
        printf("\nQueue Underflow!!\n");
        return -1;
    }
    else if(front == rear){
        int val = pqueue[front].data;
        front = rear = -1;
        return val;
    }
    else{
        int index = gethighestpriority();
        int val = pqueue[index].data;
        for(int i=index; i<rear; i++){
            pqueue[i] = pqueue[i+1];
        }
        return val;
    }
}
int peek(){
    if(isempty()){
        printf("\nQueue Underflow!!\n");
        return -1;
    }
    else{
        int index = gethighestpriority();
        int val = pqueue[index].data;
        return val;
    }
}
int display(){
    if(isempty()){
        printf("Queue is empty!!!\n");
        return 0;
    }
    for(int i=0 ; i<=rear ; i++){
        printf("Priority =>%d ---> %d\n", pqueue[i].priority, pqueue[i].data);
    }
    printf("\n");
}

int main(){
    int choice,value,priority;
    while(1){
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. Peek\n");
        printf("4. Display\n");
        printf("5. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
            printf("Enter Value: ");
            scanf("%d", &value);
            printf("Enter Priority: ");
            scanf("%d", &priority);
            enqueue(value, priority);
            break;
            case 2:
            value = dequeue();
            if(value != -1){
                printf("%d dequeue from the Priority queue!!!\n", value);
            }
            break;
            case 3:
            value = peek();
            if(value != -1){
                printf("Highest priority element ");
            }
            peek();
            break;
            case 4:
            display();
            break;
            case 5:
            printf("Exit");
            return -1;
            break;
        }
    }
}
